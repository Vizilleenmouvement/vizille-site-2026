---
import Base from '../layouts/Base.astro';
import articles from '../../articles.json';

const sorted = articles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featured = sorted[0];
const rest = sorted.slice(1);
---
<Base title="Actualites" description="Les dernieres actualites de Vizille en Mouvement.">

  <!-- Article a la une -->
  {featured && (
    <section style="background:var(--fond);padding:2rem 0;border-bottom:2px solid var(--gris-clair);">
      <div class="container">
        <div style="font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:var(--or);font-weight:700;margin-bottom:.5rem;">A la une</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center;">
          {featured.image && (
            <div style="border-radius:10px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.1);">
              <img src={featured.image} alt="" style="width:100%;height:300px;object-fit:cover;display:block;" />
            </div>
          )}
          <div>
            <div style="font-size:.72rem;color:var(--or);font-weight:600;margin-bottom:.5rem;">
              {featured.date ? new Date(featured.date).toLocaleDateString('fr-FR', {day:'numeric', month:'long', year:'numeric'}) : ''}
              {featured.categorie ? ` · ${featured.categorie}` : ''}
            </div>
            <h1 style="font-family:var(--fd);font-size:1.4rem;color:var(--texte);line-height:1.3;margin-bottom:.8rem;">{featured.titre}</h1>
            {featured.extrait && <p style="font-size:.88rem;color:var(--gris);line-height:1.7;">{featured.extrait}</p>}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Autres articles -->
  <section class="section">
    <div class="container">
      <h2 class="section-titre">Toutes les actualites</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
        {rest.map(art => (
          <article style="background:#fff;border-radius:10px;border:1px solid var(--gris-clair);overflow:hidden;transition:box-shadow .2s;">
            {art.image ? (
              <div style="height:200px;overflow:hidden;">
                <img src={art.image} alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
              </div>
            ) : (
              <div style="height:120px;background:var(--fond);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:2.5rem;opacity:.3;">📰</span>
              </div>
            )}
            <div style="padding:1.2rem;">
              <div style="font-size:.68rem;color:var(--or);font-weight:600;margin-bottom:.4rem;">
                {art.date ? new Date(art.date).toLocaleDateString('fr-FR', {day:'numeric', month:'long', year:'numeric'}) : ''}
                {art.categorie ? ` · ${art.categorie}` : ''}
              </div>
              <h3 style="font-size:.95rem;font-weight:700;margin-bottom:.5rem;color:var(--texte);line-height:1.35;">{art.titre}</h3>
              {art.extrait && <p style="font-size:.82rem;color:var(--gris);line-height:1.65;">{art.extrait.substring(0, 150)}{art.extrait.length > 150 ? '...' : ''}</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>
